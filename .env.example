# NVIDIA NIM
# Hosted API key from https://build.nvidia.com (starts with nvapi-)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted: https://integrate.api.nvidia.com/v1
# Self-hosted NIM container: http://host.docker.internal:8000/v1
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Auth
# Generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# MongoDB (internal service DNS used by the app container)
MONGO_URL=mongodb://mongo:27017
MONGO_DB=anthropic_gateway
# Random host port exposed for Mongo (avoids clashing with a local mongod)
MONGO_HOST_PORT=37017

# Gateway HTTP port (what Claude Code's ANTHROPIC_BASE_URL points at)
GATEWAY_PORT=8787
